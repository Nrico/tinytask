rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // 1. Allow users to read their own profile record (No admin helper evaluated)
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // 2. Allow admins to read any profile record
      allow read: if isAdmin();
      
      // 3. Allow users to create their own record, defaulting plan to free and role to user
      allow create: if request.auth != null && request.auth.uid == userId 
                    && (!('role' in request.resource.data) || request.resource.data.role == 'user')
                    && (!('plan' in request.resource.data) || request.resource.data.plan == 'free');

      // 4. Allow users to update their own profile fields (locking plan & role from modification/deletion)
      allow update: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.plan == resource.data.plan;

      // 5. Allow admins to update or delete any profile record (e.g. promoting roles/plans, deleting profiles)
      allow update, delete: if isAdmin();
    }
  }
}
