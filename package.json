{
  "name": "tinytask-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/hub",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "dev:hub": "npm run dev --workspace=apps/hub",
    "worker": "npm run worker --workspace=apps/hub",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:hub\" \"npm run worker\"",
    "test:playwright": "playwright test",
    "test:playwright:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "concurrently": "^8.2.2"
  }
}
